<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>53.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Account Case Log</masterLabel>
    <description>This component enables Members to review their contact tickets</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>

    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="displayComponentHeader" type="Boolean" label="Display Component Header?" description="Toggles the Component Header (H2) on/off)" default="true" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>