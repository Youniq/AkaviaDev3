<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>HasAContact__c</fullName>
    <description>Checks that the Case do have a Contact added to itself.</description>
    <formula>AND(NOT(ISNULL(ContactId)),
				NOT(ISBLANK(ContactId)))</formula>
    <label>Har Kontakt</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
