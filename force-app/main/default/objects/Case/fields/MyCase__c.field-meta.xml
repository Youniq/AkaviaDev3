<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MyCase__c</fullName>
    <description>Används för att få med både ärenden där användaren är ägare och medägare.</description>
    <formula>OR(
   OwnerId =  $User.Id ,
   CoOwner__c = $User.Id 
  )</formula>
