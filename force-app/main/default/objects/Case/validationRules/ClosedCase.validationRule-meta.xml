<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ClosedCase</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    IsClosed,
    ISPICKVAL(Status, &quot;Avslutad&quot;),
    $Profile.Name = &quot;Akavia Basic&quot;
)</errorConditionFormula>
    <errorMessage>Du kan inte redigera ett stängt ärende.</errorMessage>
</ValidationRule>
