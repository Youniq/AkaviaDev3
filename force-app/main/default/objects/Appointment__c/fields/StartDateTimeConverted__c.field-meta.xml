<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>StartDateTimeConverted__c</fullName>
    <description>Used to convert to correct timezone</description>
    <externalId>false</externalId>
    <formula>IF(DST__c, TEXT(StartDateTime__c + (2/24)) ,TEXT(StartDateTime__c + (1/24)))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Start tid/datum konverterad</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
