<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MyMeeting__c</fullName>
    <description>Used to show my meetings in list view and flow</description>
    <formula>AND(IF($User.ContactId = Account__r.PersonContactId, true, false), (ISPICKVAL(Status__c, &quot;Bokad&quot;) ||
																																																																				ISPICKVAL(Status__c, &quot;Bekräftad&quot;)))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Mitt möte</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
