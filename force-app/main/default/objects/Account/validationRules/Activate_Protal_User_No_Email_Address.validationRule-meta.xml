<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Activate_Protal_User_No_Email_Address</fullName>
    <active>false</active>
    <errorConditionFormula>AND(ActivePortalUser__c ,
 ISBLANK(PersonEmail )
)</errorConditionFormula>
