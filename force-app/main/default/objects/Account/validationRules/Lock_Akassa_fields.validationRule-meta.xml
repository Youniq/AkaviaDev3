<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Lock_Akassa_fields</fullName>
    <active>true</active>
    <errorConditionFormula>AND(AkassaLock__c , 
    OR(
       ISCHANGED(AkassaComments__c),
       ISCHANGED(AkaviaComments__c ),
       ISCHANGED(SendToAkassa__c )
      ),
 $Profile.Name &lt;&gt; &quot;IntegrationMiddleware&quot;
)</errorConditionFormula>
    <errorMessage>Dessa fält är låsta medan kommunikationen skickas till A-kassan. Gäller inte integrationer eller system admin.</errorMessage>
</ValidationRule>
