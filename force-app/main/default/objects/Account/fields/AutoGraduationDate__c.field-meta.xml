<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>AutoGraduationDate__c</fullName>
    <formula>IF(ISPICKVAL(GraduationSemester__c, &quot;VT&quot;),
DATE(VALUE(GraduationYear__c), 9, 1),
DATE(VALUE(GraduationYear__c) + 1, 2, 1))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Räknas ut automatiskt baserat på examenstermin och examensår.</inlineHelpText>
    <label>Examensdatum (auto)</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Date</type>
</CustomField>
