<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>AutoStartUniversityDate__c</fullName>
    <description>Räknas ut automatiskt baserat på Inskrivningstermin och inskricningsår</description>
    <formula>IF(ISPICKVAL(StartSemesterUniversity__c, &quot;HT&quot;),
DATE(VALUE(StartYearUniversity__c), 9, 1),
DATE(VALUE(StartYearUniversity__c), 2, 1))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Inskrivningsdatum (Auto)</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Date</type>
</CustomField>
