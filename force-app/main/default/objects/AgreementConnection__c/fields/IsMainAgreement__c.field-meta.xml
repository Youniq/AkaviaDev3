<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IsMainAgreement__c</fullName>
    <description>Checks if Type is Centralt kollektivavtal, Hängavtal or Företagsavtal, used in several flows</description>
    <formula>OR(ISPICKVAL(Agreement__r.Type__c, &apos;Centralt kollektivavtal&apos;) ,ISPICKVAL(Agreement__r.Type__c, &apos;Hängavtal&apos;),ISPICKVAL(Agreement__r.Type__c, &apos;Företagsavtal&apos;))</formula>
    <label>Is Main Agreement</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
